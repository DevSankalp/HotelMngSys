@page
@model HotelManagementSystem.Pages.Bookings.BookingsModel

<h1 class="text-2xl font-bold mb-6">Bookings</h1>

<a href="/Bookings/Create" class="bg-blue-600 text-white px-4 py-2 rounded">

    Add Booking

</a>

<table class="w-full mt-6 bg-white shadow">

    <thead>

        <tr class="bg-gray-200">

            <th>Customer</th>
            <th>Room</th>
            <th>Check In</th>
            <th>Check Out</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var booking in Model.Bookings)
        {
            <tr>

                <td>@booking.CustomerId</td>

                <td>@booking.RoomId</td>

                <td>@booking.CheckInDate</td>

                <td>@booking.CheckOutDate</td>

            </tr>
        }

    </tbody>

</table>