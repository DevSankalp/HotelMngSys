@page
@model HotelManagementSystem.Pages.Bookings.DeleteModel

<h1>Delete Booking</h1>

<h3>Are you sure you want to delete this booking?</h3>

<div>
    <strong>Guest:</strong> @Model.Booking.Guest?.FullName
</div>

<div>
    <strong>Room:</strong> @Model.Booking.Room?.RoomNumber
</div>

<div>
    <strong>Check In:</strong> @Model.Booking.CheckInDate.ToShortDateString()
</div>

<form method="post">

    <input type="hidden" asp-for="Booking.Id" />

    <button type="submit">Delete</button>
    <a asp-page="Index">Cancel</a>

</form>