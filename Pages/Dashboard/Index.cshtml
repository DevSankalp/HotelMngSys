@page
@model HotelManagementSystem.Pages.DashboardModel

<h1>Hotel Dashboard</h1>

<div class="dashboard">

    <div class="card">
        <h3>Total Rooms</h3>
        <p>@Model.TotalRooms</p>
    </div>

    <div class="card">
        <h3>Available Rooms</h3>
        <p>@Model.AvailableRooms</p>
    </div>

    <div class="card">
        <h3>Occupied Rooms</h3>
        <p>@Model.OccupiedRooms</p>
    </div>

    <div class="card">
        <h3>Total Guests</h3>
        <p>@Model.TotalGuests</p>
    </div>

    <div class="card">
        <h3>Active Bookings</h3>
        <p>@Model.ActiveBookings</p>
    </div>

    <div class="card">
        <h3>Total Revenue</h3>
        <p>₹@Model.TotalRevenue</p>
    </div>
    <hr>
</div>