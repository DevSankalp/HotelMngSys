@page
@model HotelManagementSystem.Pages.Dashboard.DashboardModel

<div class="grid grid-cols-4 gap-6">

    <div class="bg-white p-6 rounded-xl shadow hover:scale-105 transition">

        <h3 class="text-gray-500">Total Rooms</h3>
        <p class="text-3xl font-bold text-blue-600">120</p>

    </div>

    <div class="bg-white p-6 rounded-xl shadow hover:scale-105 transition">

        <h3 class="text-gray-500">Occupied</h3>
        <p class="text-3xl font-bold text-green-600">80</p>

    </div>

    <div class="bg-white p-6 rounded-xl shadow hover:scale-105 transition">

        <h3 class="text-gray-500">Bookings Today</h3>
        <p class="text-3xl font-bold text-purple-600">24</p>

    </div>

    <div class="bg-white p-6 rounded-xl shadow hover:scale-105 transition">

        <h3 class="text-gray-500">Revenue</h3>
        <p class="text-3xl font-bold text-orange-600">$8500</p>

    </div>

</div>