@page
@model HotelManagementSystem.Pages.Account.LoginModel

<div class="min-h-screen flex items-center justify-center bg-gray-100">

    <div class="bg-white p-10 rounded-xl shadow-lg w-96">

        <h2 class="text-2xl font-bold mb-6 text-center">
            Hotel Admin Login
        </h2>

        <form method="post">

            <input asp-for="Username" placeholder="Username" class="w-full p-3 border rounded mb-4" />

            <input asp-for="Password" type="password" placeholder="Password" class="w-full p-3 border rounded mb-4" />

            <button class="w-full bg-blue-600 text-white p-3 rounded hover:bg-blue-700 transition">
                Login
            </button>

        </form>

    </div>

</div>