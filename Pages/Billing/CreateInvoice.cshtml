@page
@model HotelManagementSystem.Pages.Billing.CreateInvoiceModel

<h1 class="text-2xl font-bold mb-6">Create Invoice</h1>

<form method="post">
    <input asp-for="Invoice.BookingId" placeholder="Booking Id" />
    <input asp-for="Invoice.TotalAmount" placeholder="Total Amount" />
    <input asp-for="Invoice.IssuedDate" type="date" />
    <button class="bg-blue-600 text-white px-4 py-2 rounded">Save</button>
</form>