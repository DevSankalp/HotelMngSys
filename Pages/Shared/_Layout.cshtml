<!DOCTYPE html>
<html>
<head>
    <title>Hotel Management</title>
    <link href="/css/site.css" rel="stylesheet">
    <link href="/css/output.css" rel="stylesheet">
</head>
<script src="/_framework/aspnetcore-browser-refresh.js"></script>

<body class="bg-gray-100">

    <div class="flex">

        <!-- Sidebar -->

        <div class="w-64 bg-blue-900 text-white min-h-screen p-6">

            <h1 class="text-2xl font-bold mb-6">Hotel Admin</h1>

            <nav class="space-y-3">

                <a href="/Account" class="block hover:bg-blue-700 p-2 rounded">
                    Login
                </a>

                <a href="/Dashboard" class="block hover:bg-blue-700 p-2 rounded">
                    Dashboard
                </a>

                <a href="/Rooms" class="block hover:bg-blue-700 p-2 rounded">
                    Rooms
                </a>

                <a href="/Bookings" class="block hover:bg-blue-700 p-2 rounded">
                    Bookings
                </a>

                <a href="/Customers" class="block hover:bg-blue-700 p-2 rounded">
                    Customers
                </a>

                <a href="/Roles" class="block hover:bg-blue-700 p-2 rounded">
                    Roles
                </a>

                <a href="/Billing/Invoice" class="block hover:bg-blue-700 p-2 rounded">
                    Invoices
                </a>

                <a href="/Billing/Payment" class="block hover:bg-blue-700 p-2 rounded">
                    Payments
                </a>

            </nav>

        </div>

        <!-- Content -->

        <div class="flex-1 p-8">

            @RenderBody()

        </div>

    </div>

</body>

</html>