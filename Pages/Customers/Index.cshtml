@page
@model HotelManagementSystem.Pages.Customers.CustomersModel

<h1 class="text-2xl font-bold mb-6">Customers</h1>

<a href="/Customers/Create" class="bg-blue-600 text-white px-4 py-2 rounded">

    Add Customer

</a>

<table class="w-full mt-6 bg-white shadow">

    <thead>

        <tr class="bg-gray-200">

            <th>Name</th>
            <th>Phone</th>
            <th>Email</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var customer in Model.Customers)
        {
            <tr>

                <td>@customer.FullName</td>
                <td>@customer.Phone</td>
                <td>@customer.Email</td>

            </tr>
        }

    </tbody>

</table>