@page
@model HotelManagementSystem.Pages.Roles.RolesModel

<h1 class="text-2xl font-bold mb-6">Roles</h1>

<a href="/Roles/Create" class="bg-blue-600 text-white px-4 py-2 rounded">
    Add Role
</a>

<table class="w-full mt-6 bg-white shadow">
    <thead>
        <tr class="bg-gray-200">
            <th>Name</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model.Roles)
        {
            <tr>
                <td>@role.RoleName</td>
            </tr>
        }
    </tbody>
</table>