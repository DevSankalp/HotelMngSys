@page
@model HotelManagementSystem.Pages.Rooms.DeleteModel

<h1>Delete Room</h1>

<h3>Are you sure you want to delete this room?</h3>

<div>
    Room Number: @Model.Room.RoomNumber
</div>

<form method="post">
    <input type="hidden" asp-for="Room.Id" />

    <button type="submit">Delete</button>
    <a href="/Rooms">Cancel</a>

</form>