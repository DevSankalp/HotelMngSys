@page "{id:int}"
@model HotelManagementSystem.Pages.Rooms.EditRoomModel

<h1 class="text-2xl font-bold mb-6">Edit Room</h1>

<form method="post">
    <input type="hidden" asp-for="Room.RoomId" />
    <input asp-for="Room.RoomNumber" placeholder="Room Number" />
    <input asp-for="Room.RoomTypeId" placeholder="Type ID" />
    <input asp-for="Room.TypeName" placeholder="Type Name" />
    <input asp-for="Room.Price" placeholder="Price" />
    <input asp-for="Room.Status" placeholder="Status" />
    <button class="bg-blue-600 text-white px-4 py-2 rounded">Save</button>
</form>