@page
@model HotelManagementSystem.Pages.Rooms.RoomsModel

<h1 class="text-xl font-bold mb-6">Rooms</h1>

<a href="/Rooms/Create" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
    Add Room
</a>

<table class="w-full mt-6 bg-white shadow rounded">

    <thead class="bg-gray-200">

        <tr>
            <th class="p-3">Room Number</th>
            <th>Type</th>
            <th>Price</th>
            <th>Status</th>
        </tr>

    </thead>

    <tbody>

        @foreach (var room in Model.Rooms)
        {
            <tr class="border-t hover:bg-gray-100 transition">
                <td class="p-3">@room.RoomNumber</td>
                <td>@room.TypeName</td>
                <td>@room.Price</td>
                <td>@room.Status</td>
            </tr>
        }

    </tbody>

</table>